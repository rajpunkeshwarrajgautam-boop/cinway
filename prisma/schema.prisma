generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  subscriptionTier      String?   @default("NONE")
  subscriptionStatus    String?   @default("INACTIVE")
  subscriptionEndDate   DateTime?
  cashfreeCustomerId    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  sessions       Session[]
  accounts       Account[]
  profiles       Profile[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Profile {
  id        String   @id @default(cuid())
  name      String
  imageUrl  String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  myList    Favorite[]
}

model Movie {
  id          String   @id @default(cuid())
  tmdbId      Int      @unique
  title       String
  description String   @db.Text
  videoUrl    String
  thumbnailUrl String
  backdropUrl String?
  genre       String
  duration    String?
  releaseYear Int
  rating      Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  favorites   Favorite[]

  @@index([genre])
  @@index([releaseYear])
}

model Favorite {
  id        String   @id @default(cuid())
  movieId   String
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([movieId, profileId])
  @@index([profileId])
}
