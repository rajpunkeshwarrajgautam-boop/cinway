{
  "name": "netflix-clone-premium",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "dev": "next dev",
    "build": "npx prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run build",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-tv": "tsx prisma/seed-tv.ts",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@cashfreepayments/cashfree-js": "^1.0.7",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.19.3",
    "bcrypt": "^5.1.1",
    "firebase": "^12.12.0",
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.471.0",
    "next": "^16.2.4",
    "next-auth": "^4.24.14",
    "nodemailer": "^8.0.7",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "swr": "^2.3.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22",
    "@types/nodemailer": "^6.4.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "axios": "^1.7.9",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.4",
    "firebase-tools": "^15.15.0",
    "prisma": "^6.19.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
